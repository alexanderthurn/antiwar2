# Copy to .env (or .env.local for machine-only overrides).
# Vite loads .env, .env.[mode], and *.local files automatically.

# Online highscores API base URL (omit or leave empty for local-only scores)
VITE_HIGHSCORE_URL=https://feuerware.com/2025/antiwar2/backend/api

# Loose sprite hot-reload in dev (normally enabled via `npm run art` → .env.art)
# VITE_LOOSE_SPRITES=true
